{
  "manifest_version": 3,
  "name": "BrowserPilot for Edge",
  "version": "0.1.10",
  "description": "Let an AGNT agent understand and operate the Microsoft Edge tab you are already using.",
  "action": {
    "default_title": "BrowserPilot for Edge",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel",
    "webNavigation",
    "contextMenus"
  ],
  "optional_permissions": [
    "notifications",
    "downloads",
    "clipboardRead",
    "clipboardWrite",
    "alarms",
    "offscreen",
    "tabCapture"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3333/*",
    "https://localhost:3333/*",
    "http://localhost:8642/*",
    "https://localhost:8642/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
