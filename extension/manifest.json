{
  "manifest_version": 3,
  "name": "BrowserPilot",
  "version": "0.3.10",
  "version_name": "0.3.10 Default Agent Fallback",
  "description": "Let an AGNT agent understand and operate the browser tab you are already using.",
  "action": {
    "default_title": "BrowserPilot",
    "default_icon": {}
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel",
    "webNavigation",
    "contextMenus"
  ],
  "optional_permissions": [
    "alarms",
    "bookmarks",
    "browsingData",
    "clipboardRead",
    "clipboardWrite",
    "contentSettings",
    "cookies",
    "desktopCapture",
    "downloads",
    "history",
    "identity",
    "idle",
    "management",
    "nativeMessaging",
    "notifications",
    "offscreen",
    "pageCapture",
    "privacy",
    "sessions",
    "tabCapture",
    "tabGroups",
    "topSites",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3333/*",
    "https://localhost:3333/*",
    "http://localhost:8642/*",
    "https://localhost:8642/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
